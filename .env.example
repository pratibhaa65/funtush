# ── PostgreSQL (Prisma) ──────────────────────────────
DATABASE_URL="postgresql://funtush:funtush@localhost:5432/funtush?schema=public"

# ── Redis (sessions, cache, rate limiting) ───────────
REDIS_URL="redis://localhost:6379"

# ── MongoDB (audit logs, analytics, email queue) ─────
MONGO_URL="mongodb://localhost:27017/funtush"

# ── Auth ─────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-string"

# ── API ──────────────────────────────────────────────
PORT=4000

# ── Meilisearch (marketplace search) ─────────────────
# Local dev can run without a master key; production MUST set one.
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY=""

# -- Cloudflare R2 Storage -----------------------------
STORAGE_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=funtush
CDN_BASE_URL=

# Payment Method Encryption 
ENCRYPTION_KEY=