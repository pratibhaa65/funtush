{
  "name": "funtush",
  "version": "0.0.0",
  "private": true,
  "description": "Funtush monorepo â B2B2C multi-tenant SaaS marketplace for trekking agencies.",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@funtush/config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.22.4",
    "turbo": "^2.5.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "ioredis": "^5.11.1",
    "prisma": "^6.7.0"
  }
