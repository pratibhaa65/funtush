{
  "name": "@funtush/api",
  "version": "0.0.0",
  "private": true,
  "description": "Funtush backend API (Node.js + Express).",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .turbo coverage"
  },
  "dependencies": {
    "@funtush/database": "workspace:*",
    "@funtush/shared": "workspace:*",
    "@funtush/utils": "workspace:*",
    "@prisma/client": "^7.8.0",
    "express": "^4.22.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0"
  }
}