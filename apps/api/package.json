{
  "name": "@funtush/api",
  "version": "0.0.0",
  "private": true,
  "description": "Funtush backend API (Node.js + Express).",
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .turbo coverage"
  },
  "dependencies": {
    "@funtush/database": "workspace:*",
