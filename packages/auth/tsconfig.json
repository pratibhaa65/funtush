{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@funtush/database": [
        "../database/src/index.ts"
      ]
    },
    "noEmit": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0"
  },
  "references": [
    { "path": "../database" }
  ],
  "include": [
    "src",
    "../../apps/api/src/types/express.d.ts"
  ]
}