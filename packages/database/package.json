{
  "name": "@funtush/database",
  "version": "0.0.0",
  "private": true,
  "description": "Data-access layer (PostgreSQL/MongoDB/Redis) for Funtush.",
  "type": "commonjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .turbo coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "build": "tsc -p tsconfig.json",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@funtush/shared": "workspace:*",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.0",
    "mongoose": "^9.6.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "prisma": "6.19.3",
    "tsx": "^4.22.4"
  }
}